# 1. whitespace & trimming
WITH_SPACE = "  spaced value  "
TRIM_TEST=  no_quotes_needed

# 2. delimiter edge cases
MULTIPLE_EQUALS=key=value=extra
URL=https://api.example.com/v1?query=test
EMPTY_VAL=

# 3. single quote literalism (no newline conversion)
SINGLE_QUOTE='literal\nnewline'
SQ_ESCAPED='It\'s a string'
SQ_INTERNAL_DQ='String with "double" quotes'

# 4. double quote interpreted (contains real newline)
DOUBLE_QUOTE="interpreted\nnewline"
DQ_ESCAPED="Contains \"quotes\" and \\ backslashes"
DQ_INTERNAL_SQ="String with 'single' quotes"

# 5. comments & invalid lines
# These lines should be IGNORED by parser:
# This is a full-line comment
STRAY_TEXT_WITHOUT_EQUALS
   # comment with leading whitespace
# nested quotes
MIXED_QUOTES="'nested'"
# this is a full-line comment
   # Comment with leading whitespace
KEY_WITH_COMMENT=value # this is an inline comment
KEY_WITH_COMMENT_SECRET="secret#password" # this is an inline comment

# 6. case sensitivity
# Since file has 'basic=lower', cfg.get("BASIC") should be null or different
BASIC=basic
BASIC=UPPERCASE BASIC
basic=lowercase basic

# 7. exported values should work fine
export EXPORTED_VAR="this is an exported var"
